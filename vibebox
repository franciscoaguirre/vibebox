#!/usr/bin/ruby

require "tmpdir"
require "shellwords"
require "fileutils"
require "json"

CWD = File.expand_path(Dir.pwd)

config_path = File.join(ENV["HOME"], ".vibebox.json")
config = {}
config = JSON.parse(File.read(config_path)) if File.exist?(config_path)
config_modified = []

def ask_confirmation(prompt = nil)
    loop do
        if prompt
            STDOUT.print "#{prompt}> "
        else
            STDOUT.print "y/n> "
        end
        STDOUT.flush
        yesno = STDIN.gets.strip.downcase
        return true if yesno == "y" || yesno == "yes"
        return false if yesno == "n" || yesno == "no"
    end
end

ask_config = lambda do |key, label, prompt|
    unless config.include? key
        STDOUT.print "#{prompt}> "
        STDOUT.flush
        value = STDIN.gets.strip
        config[key] = value
        config_modified << [label, value]
    end
end

ask_config.call "home", "Sandboxed $HOME path", "Type in the path to store your sandboxed $HOME"
ask_config.call "github_token", "GitHub read-only token (GH_TOKEN)", "Paste a read-only fine-grained GitHub token (or leave blank for anonymous access)"

unless config_modified.empty?
    puts
    puts "These are your new settings:"
    config_modified.each do |label, value|
        puts "  #{label}: '#{value}'"
    end
    puts
    puts "Do you confirm these settings?"
    exit 1 unless ask_confirmation

    File.write(config_path, JSON.pretty_generate(config) + "\n")
    puts
    puts "Config saved to '#{config_path}'!"
    sleep 3
end

FileUtils.mkdir_p config["home"]

uid = `id -u`.strip
gid = `id -g`.strip
raise if uid.empty? || gid.empty?

# Podman (rootless) remaps UIDs via subuid ranges, so it needs --userns=keep-id
# to line the container's `vibe` user up with the host user. Docker runs the uid
# as-is and rejects "keep-id" as an invalid USER mode, so only pass it for Podman.
is_podman = `docker --version 2>/dev/null`.strip.downcase.include?("podman")

PACKAGES = %w{
    build-essential
    ca-certificates
    cmake
    curl
    file
    g++
    gcc
    git
    imagemagick
    inetutils-ping
    iproute2
    jq
    less
    libgl1
    libgl1-mesa-dri
    libegl1
    libxkbcommon0
    libfontconfig1
    libdbus-1-3
    libasound2-dev
    libclang-18-dev
    libclang-common-18-dev
    libglib2.0-dev
    libpixman-1-dev
    libpython3-dev
    libssl-dev
    locales
    make
    mesa-utils
    mc
    net-tools
    ninja-build
    pkg-config
    protobuf-compiler
    python3
    python3-matplotlib
    python3-numpy
    python3-pil
    python3-scipy
    ripgrep
    ruby
    sudo
    x11-apps
    xvfb
}

IMAGE_TAG = "vibebox"
SANDBOX_USERNAME = "vibe"

DOCKERFILE = <<-EOS
FROM ubuntu:24.04
MAINTAINER Jan Bujak (j@exia.io)

RUN DEBIAN_FRONTEND="noninteractive" apt-get update && DEBIAN_FRONTEND="noninteractive" apt-get install -y --no-install-recommends #{PACKAGES.join " "}
RUN bash -c 'echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen' && locale-gen en_US.UTF-8 && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
RUN sed -i -E "s/ ALL$/ NOPASSWD: ALL/g" /etc/sudoers && sed -i 's/root:\\*/root:$6$Fc5teNQbSppq8I57$A1f7wwDpDKyHzb.0OPW6fpASde7sFtdiAA.2AZakKR8\\/vQ8WiRySJBY2Ueyk0N0O2FqEkaGRFakwgSH.kodG2\\//' /etc/shadow && userdel ubuntu && groupadd -o -g #{gid} #{SANDBOX_USERNAME} && useradd --uid #{uid} -g #{SANDBOX_USERNAME} -Ms /bin/bash #{SANDBOX_USERNAME} && usermod -a -G sudo #{SANDBOX_USERNAME} && mkdir -p /home/vibe && chown #{SANDBOX_USERNAME}:#{SANDBOX_USERNAME} /home/vibe && chmod 755 /home/ubuntu
RUN mkdir -p -m 755 /etc/apt/keyrings && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && DEBIAN_FRONTEND="noninteractive" apt-get update && DEBIAN_FRONTEND="noninteractive" apt-get install -y --no-install-recommends gh
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && DEBIAN_FRONTEND="noninteractive" apt-get install -y --no-install-recommends nodejs && corepack enable && corepack prepare pnpm@latest --activate
USER #{SANDBOX_USERNAME}
WORKDIR /home/#{SANDBOX_USERNAME}
COPY .entrypoint.rb /home/ubuntu/.entrypoint.rb
EOS

SETUP_SH = <<-EOS
#!/usr/bin/ruby
require "fileutils"
require "shellwords"

ENV["PATH"] = [
    "/home/#{SANDBOX_USERNAME}/.local/bin",
    "/home/#{SANDBOX_USERNAME}/.kimi-code/bin",
    "/home/#{SANDBOX_USERNAME}/.cargo/bin",
    "/home/#{SANDBOX_USERNAME}/.opencode/bin",
    ENV["PATH"]
].join(":")

# The container image only ships a common terminfo database. Force a
# widely-supported, color-capable terminal type so color rendering works
# regardless of the host terminal emulator (alacritty, kitty, etc.).
ENV["TERM"] = "xterm-256color"
ENV.delete("NO_COLOR")

[".bashrc", ".profile"].each do |filename|
    target = "/home/#{SANDBOX_USERNAME}/" + filename
    FileUtils.cp("/home/ubuntu/" + filename, target) unless File.exist?(target)
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.local/bin/uv"
    puts "Installing uv...."
    system "curl -LsSf https://astral.sh/uv/install.sh | sh"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.local/bin/vibe"
    puts "Installing mistral-vibe..."
    system "/home/#{SANDBOX_USERNAME}/.local/bin/uv tool install mistral-vibe"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.opencode/bin/opencode"
    puts "Installing opencode..."
    system "curl -fsSL https://opencode.ai/install | bash"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.local/bin/claude"
    puts "Installing claude..."
    system "curl -fsSL https://claude.ai/install.sh | bash"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.cargo/bin/rustup"
    puts "Installing rustup..."
    system "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.cargo/bin/cargo-remote"
    puts "Installing cargo-remote..."
    system "/home/#{SANDBOX_USERNAME}/.cargo/bin/cargo install cargo-remote"
    raise "installation failed" if $?.exitstatus != 0
end

unless File.exist? "/home/#{SANDBOX_USERNAME}/.kimi-code/bin/kimi"
    puts "Installing kimi..."
    system "curl -fsSL https://code.kimi.com/kimi-code/install.sh | bash"
    raise "installation failed" if $?.exitstatus != 0
end

exec "/bin/bash"
EOS

Dir.mktmpdir do |tmpdir|
    Dir.chdir(tmpdir) do
        File.write(".entrypoint.rb", SETUP_SH)
        File.chmod(0755, ".entrypoint.rb")
        File.write("Dockerfile", DOCKERFILE)
        command = "docker build -f Dockerfile -t #{IMAGE_TAG.shellescape} ./"
        system command
        raise unless $?.exitstatus == 0
    end
end

# The container image only ships common terminfo entries; exotic host terminals
# like alacritty/kitty have no entry inside the container and break color output.
# Force xterm-256color so colors always work.
term = "xterm-256color"

command = [
    "docker", "run",
    "--rm",
    "--hostname=localhost",
    "--tmpfs=/tmp:exec",
    "--ipc=host",
    "--net=host",
    "--tty",
    "--interactive",
    "--volume", "#{config["home"]}:/home/#{SANDBOX_USERNAME}",
    "--volume", "#{CWD}:#{CWD}",
    "-w", CWD,
    "-e", "TERM=#{term}",
    "--entrypoint", "/home/ubuntu/.entrypoint.rb"
]

command += ["--userns=keep-id"] if is_podman

github_token = config["github_token"].to_s.strip
command += ["-e", "GH_TOKEN=#{github_token}"] unless github_token.empty?

if File.exist? "/dev/kvm"
    kvm_group = `getent group kvm`.strip.split(":")[2]
    if kvm_group != nil
        command += [
            "--device", "/dev/kvm",
            "--group-add", kvm_group,
        ]
    end
end

ARGV.each do |arg|
    command << arg
end

# Worktrunk places each worktree in a sibling folder named "<base-repo>.<branch>".
# A worktree's .git is a file pointing into the base repo's .git directory, so git
# operations inside the container need the base repo mounted too. Derive the base
# repo from the part of the folder name before the first dot and, when that sibling
# exists, mount it at the same absolute path so the worktree's gitdir resolves.
base_repo_name = File.basename(CWD).split(".", 2).first
base_repo_path = File.join(File.dirname(CWD), base_repo_name)

# Track the container target paths already mounted so later reference mounts can
# skip anything that would collide (Docker errors on duplicate target paths).
mounted_paths = [CWD]

if base_repo_path != CWD && Dir.exist?(base_repo_path)
    command += ["--volume", "#{base_repo_path}:#{base_repo_path}"]
    mounted_paths << base_repo_path
    puts "Mounting base repository: #{base_repo_path}"
end

# Extra read-only reference mounts. Add a "mounts" array of absolute paths to
# ~/.vibebox.json to make other repos on your machine visible inside the
# container. Each is mounted read-only at its same absolute path, so absolute
# paths resolve identically inside and outside the container.
Array(config["mounts"]).each do |mount|
    path = File.expand_path(mount.to_s)
    unless Dir.exist?(path)
        puts "Skipping missing mount: #{path}"
        next
    end
    if mounted_paths.include?(path)
        puts "Skipping already-mounted reference: #{path}"
        next
    end
    command += ["--volume", "#{path}:#{path}:ro"]
    mounted_paths << path
    puts "Mounting reference (read-only): #{path}"
end

command << IMAGE_TAG

exec *command
